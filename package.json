{
  "name": "start-ui-native",
  "private": true,
  "main": "expo-router/entry",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "prebuild": "expo prebuild",
    "start": "expo start",
    "dev": "pnpm gen:api && expo start --go",
    "dev:build:android": "APP_ENV=development expo prebuild --clean && expo run:android",
    "dev:build:ios": "APP_ENV=development expo prebuild --clean && expo run:ios",
    "dev:storybook": "APP_ENV=storybook expo start --go --port 8083",
    "storybook:generate": "sb-rn-get-stories --config-path .rnstorybook",
    "build:staging:android": "APP_ENV=staging expo prebuild --clean && expo run:android --variant release",
    "build:staging:ios": "APP_ENV=staging expo prebuild --clean && expo run:ios --configuration Release",
    "build:production:android": "APP_ENV=production expo prebuild --clean && expo run:android --variant release",
    "build:production:ios": "APP_ENV=production expo prebuild --clean && expo run:ios --configuration Release",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint ./src --fix",
    "lint:ts": "tsc --noEmit",
    "pretty": "prettier -w .",
    "gen:api": "dotenv -- npx @hey-api/openapi-ts -f ./src/lib/hey-api/config.ts",
    "gen:icons": "svgr --config-file src/components/icons/svgr.config.cjs src/components/icons/svg-sources && prettier -w src/components/icons/generated",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@bearstudio/ui-state": "1.1.0",
    "@better-auth/expo": "1.5.5",
    "@dev-plugins/async-storage": "0.4.0",
    "@dev-plugins/react-navigation": "0.4.0",
    "@dev-plugins/react-query": "0.4.0",
    "@expo/metro-runtime": "56.0.12",
    "@expo/ui": "56.0.13",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@rn-primitives/avatar": "1.2.0",
    "@rn-primitives/slot": "1.2.0",
    "@shopify/flash-list": "2.0.2",
    "@t3-oss/env-core": "0.13.11",
    "@tanstack/eslint-plugin-query": "5.91.4",
    "@tanstack/react-form": "1.28.4",
    "@tanstack/react-query": "5.90.21",
    "better-auth": "1.5.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dayjs": "1.11.19",
    "expo": "56.0.4",
    "expo-application": "56.0.3",
    "expo-constants": "56.0.15",
    "expo-crypto": "56.0.3",
    "expo-device": "56.0.4",
    "expo-font": "56.0.5",
    "expo-haptics": "56.0.3",
    "expo-image": "56.0.9",
    "expo-keep-awake": "56.0.3",
    "expo-linking": "56.0.11",
    "expo-localization": "56.0.6",
    "expo-network": "56.0.4",
    "expo-router": "56.2.6",
    "expo-secure-store": "56.0.4",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-symbols": "56.0.5",
    "expo-system-ui": "56.0.5",
    "expo-updates": "56.0.16",
    "expo-web-browser": "56.0.5",
    "i18next": "25.8.18",
    "lucide-react-native": "0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-i18next": "16.5.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "0.21.2",
    "react-native-worklets": "0.8.3",
    "sonner-native": "0.23.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "uniwind": "1.7.0",
    "zod": "4.3.6",
    "zustand": "5.0.11"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@eslint-react/eslint-plugin": "2.13.0",
    "@eslint/js": "9.39.4",
    "@gorhom/bottom-sheet": "5.2.14",
    "@hey-api/openapi-ts": "0.94.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@storybook/addon-ondevice-actions": "10.4.1",
    "@storybook/addon-ondevice-controls": "10.4.1",
    "@storybook/react-native": "10.4.1",
    "@svgr/cli": "8.1.0",
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "dotenv-cli": "11.0.0",
    "eslint": "9.39.4",
    "eslint-config-expo": "56.0.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-storybook": "10.4.1",
    "eslint-plugin-unicorn": "63.0.0",
    "lefthook": "2.1.4",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "storybook": "10.4.1",
    "ts-plugin-sort-import-suggestions": "1.0.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bearstudio/start-ui-native.git"
  },
  "contributors": [
    {
      "name": "Nicolas Torion",
      "email": "nicolas@bearstudio.fr",
      "url": "https://github.com/ntorionbearstudio"
    },
    {
      "name": "Hugo Pérard",
      "email": "hugo.perard@bearstudio.fr",
      "url": "https://github.com/hugoperard"
    },
    {
      "name": "Omar Borji",
      "url": "https://github.com/omar-bear"
    }
  ],
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bearstudio/start-ui-native/issues"
  },
  "homepage": "https://github.com/bearstudio/start-ui-native#readme",
  "pnpm": {
    "overrides": {
      "expo-constants": "56.0.15"
    },
    "onlyBuiltDependencies": [
      "lefthook",
      "unrs-resolver"
    ]
  }
}
